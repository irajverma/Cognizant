<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">

    <!-- Enable AspectJ AutoProxying for LoggingAspect -->
    <aop:aspectj-autoproxy />

    <!-- Enable Component Scanning for com.library package (Exercise 6) -->
    <context:component-scan base-package="com.library" />

    <!-- 
      Explicit XML bean wiring (Exercises 1, 2, 7)
      Uncomment these to test explicit XML-based injection.
      If component scan is enabled, Spring will also detect beans annotated with @Service/@Repository.
    -->
    <!-- 
    <bean id="bookRepository" class="com.library.repository.BookRepository" />

    <bean id="bookServiceSetter" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository" />
    </bean>

    <bean id="bookServiceConstructor" class="com.library.service.BookService">
        <constructor-arg ref="bookRepository" />
    </bean>

    <bean id="loggingAspect" class="com.library.aspect.LoggingAspect" />
    -->

</beans>
